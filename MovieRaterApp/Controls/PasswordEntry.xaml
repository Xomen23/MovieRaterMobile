<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MovieRaterApp.Controls.PasswordEntry"
             x:Name="Root">

    <Grid ColumnDefinitions="*,Auto">
        <Entry x:Name="PasswordField"
               Grid.Column="0"
               Text="{Binding Text, Source={x:Reference Root}}"
               Placeholder="{Binding Placeholder, Source={x:Reference Root}}"
               IsPassword="True" />
        <Button x:Name="ToggleButton"
                Grid.Column="1"
                Text="👁"
                Clicked="OnToggleClicked"
                BackgroundColor="Transparent"
                BorderWidth="0"
                Padding="8,0"
                VerticalOptions="Center"
                SemanticProperties.Description="Prikaži ili sakrij lozinku" />
    </Grid>

</ContentView>
