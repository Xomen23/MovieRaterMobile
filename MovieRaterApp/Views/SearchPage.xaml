<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MovieRaterApp.Views.SearchPage"
             Title="Search">

    <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">
        <Label Text="SearchPage"
               FontSize="28"
               HorizontalOptions="Center" />
        <Label Text="Placeholder — glavni ekran (pretraga filmova)"
               HorizontalTextAlignment="Center"
               HorizontalOptions="Center" />
        <Button Text="Idi na Movie Details"
                Clicked="OnGoToMovieDetailsClicked" />
        <Button Text="Idi na My Reviews (kolekcija)"
                Clicked="OnGoToMyReviewsClicked" />
        <Button Text="Nazad na Login"
                Clicked="OnGoBackClicked" />
    </VerticalStackLayout>

</ContentPage>
