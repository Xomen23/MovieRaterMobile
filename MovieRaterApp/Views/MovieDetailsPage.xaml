<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:models="clr-namespace:MovieRaterApp.Models"
             x:Class="MovieRaterApp.Views.MovieDetailsPage"
             Title="Detalji filma">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Profil"
                     Order="Primary"
                     Command="{Binding GoToProfileCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="Center" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding ErrorMessage, Converter={toolkit:IsStringNotNullOrEmptyConverter}}" />

            <Image Source="{Binding MovieImageUrl}"
                   HeightRequest="220"
                   Aspect="AspectFill"
                   BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#333333}" />

            <Label Text="{Binding MovieTitle}"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="{Binding MovieYear}"
                   FontSize="16"
                   TextColor="Gray" />

            <Label Text="{Binding AverageRatingDisplay}"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" />

            <Label Text="{Binding MoviePlot}"
                   FontSize="14"
                   LineBreakMode="WordWrap" />

            <BoxView HeightRequest="1"
                     Color="{AppThemeBinding Light=#DDDDDD, Dark=#444444}" />

            <Label Text="Ostavi / izmeni svoju recenziju"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Label Text="{Binding MyRatingInput, StringFormat='Ocena: {0}/10'}" />

            <Slider Minimum="1"
                    Maximum="10"
                    Value="{Binding MyRatingInput}"
                    ThumbColor="{StaticResource Primary}"
                    MinimumTrackColor="{StaticResource Primary}" />

            <Editor Text="{Binding MyReviewTextInput}"
                    Placeholder="Komentar (opciono)"
                    AutoSize="TextChanges"
                    MinimumHeightRequest="80" />

            <Button Text="{Binding SubmitReviewButtonText}"
                    Command="{Binding SubmitReviewCommand}"
                    IsEnabled="{Binding CanSubmitReview}" />

            <Button Text="Obriši recenziju"
                    Command="{Binding DeleteMyReviewCommand}"
                    IsVisible="{Binding HasMyReview}"
                    BackgroundColor="Transparent"
                    TextColor="Red"
                    BorderWidth="0" />

            <BoxView HeightRequest="1"
                     Color="{AppThemeBinding Light=#DDDDDD, Dark=#444444}" />

            <Label Text="Sve recenzije"
                   FontSize="18"
                   FontAttributes="Bold" />

            <CollectionView ItemsSource="{Binding Reviews}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Review">
                        <Border Padding="12"
                                Margin="0,0,0,8"
                                Stroke="{AppThemeBinding Light=#DDDDDD, Dark=#444444}"
                                StrokeThickness="1">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Username}"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding Rating, StringFormat='★ {0}/10'}"
                                       TextColor="{StaticResource Primary}" />
                                <Label Text="{Binding ReviewText}"
                                       LineBreakMode="WordWrap" />
                                <Label Text="{Binding CreatedAt}"
                                       FontSize="12"
                                       TextColor="Gray" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
