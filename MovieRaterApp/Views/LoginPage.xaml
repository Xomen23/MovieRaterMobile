<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MovieRaterApp.Views.LoginPage"
             Title="Login">

    <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">
        <Label Text="LoginPage"
               FontSize="28"
               HorizontalOptions="Center" />
        <Label Text="Placeholder — prijava korisnika"
               HorizontalOptions="Center" />
        <Button Text="Idi na Register"
                Clicked="OnGoToRegisterClicked" />
        <Button Text="Idi na Search (simulacija login-a)"
                Clicked="OnGoToSearchClicked" />
    </VerticalStackLayout>

</ContentPage>
